<mxfile host="Electron" agent="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/28.2.5 Chrome/138.0.7204.251 Electron/37.6.1 Safari/537.36" version="28.2.5">
  <diagram name="Page-1" id="O--WKBzsO0Jo4_GO3PbQ">
    <mxGraphModel dx="1236" dy="875" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="ainLi33GgQbYzg2RrP6c-2" value="To-Do:&amp;nbsp;&lt;div&gt;- Generate CubeMX files&amp;nbsp;&lt;/div&gt;&lt;div&gt;- Setup I2C Driver in CubeMX&lt;/div&gt;&lt;div&gt;- Setup UART drivers&lt;/div&gt;&lt;div&gt;- Download drivers for accelerometer and gyroscope&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- Print IMU data to serial monitor&amp;nbsp;&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;- Set up DMA in CubeMX&amp;nbsp;&lt;/span&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;- Implement Complimentary filter&amp;nbsp;&lt;/div&gt;&lt;div&gt;- Test complimentary filter&amp;nbsp;&lt;/div&gt;&lt;div&gt;- Implement Circular buffer&amp;nbsp;&lt;/div&gt;&lt;div&gt;- Write Linear algebra library&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- Matrix multiplication&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- Matrix transpose&amp;nbsp;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- Matrix inversion&amp;nbsp;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- Matrix addition&lt;br&gt;&lt;/div&gt;&lt;div&gt;- State space model for 6DOF Accel + Gyro&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="20" y="18" width="300" height="270" as="geometry" />
        </mxCell>
        <mxCell id="ainLi33GgQbYzg2RrP6c-3" value="Idea 1 Peripheral&#xa;   ↓&#xa;DMA&#xa;   ↓&#xa;Ping-pong buffers&#xa;   ↓&#xa;ISR copies into&#xa;   ↓&#xa;Circular buffer (head/tail)&#xa;   ↓&#xa;Application parser" style="text;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="20" y="270" width="170" height="180" as="geometry" />
        </mxCell>
        <mxCell id="ainLi33GgQbYzg2RrP6c-4" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" vertex="1" parent="1">
          <mxGeometry x="40" y="500" width="717" height="343" as="geometry" />
        </mxCell>
        <mxCell id="ainLi33GgQbYzg2RrP6c-5" value="Write to CTRL_REG1_G to switch to Accelerometer + Gyro mode" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="40" y="460" width="370" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ainLi33GgQbYzg2RrP6c-6" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" vertex="1" parent="1">
          <mxGeometry x="40" y="860" width="746" height="601" as="geometry" />
        </mxCell>
        <mxCell id="ainLi33GgQbYzg2RrP6c-7" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" vertex="1" parent="1">
          <mxGeometry x="820" y="500" width="801" height="685" as="geometry" />
        </mxCell>
        <mxCell id="ainLi33GgQbYzg2RrP6c-8" value="Features&amp;nbsp;&lt;div&gt;- 32 blocks of 3x16 bit FIFO for each Gyroscope output&lt;/div&gt;&lt;div&gt;- Buffer works in five modes: Bypass, FIFO-mode, Continuous mode, Continuous-to-FIFO, and Bypass-to-Continuous&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="320" y="18" width="650" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ainLi33GgQbYzg2RrP6c-9" value="Design Questions:&amp;nbsp;&lt;div&gt;- What is the output data rate (ODR) I will use for Accel + Gryo&lt;/div&gt;&lt;div&gt;- How large does the DMA buffers need to be to ensure buffers do not overfill&amp;nbsp;&lt;/div&gt;&lt;div&gt;- What alpha is optimal for complimentary filter (testing needed)&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="320" y="205" width="430" height="90" as="geometry" />
        </mxCell>
        <mxCell id="ainLi33GgQbYzg2RrP6c-10" value="lsm9ds1 drivers from ST&lt;div&gt;https://github.com/STMicroelectronics/STMems_Standard_C_drivers/tree/master/lsm9ds1_STdC&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="320" y="310" width="540" height="40" as="geometry" />
