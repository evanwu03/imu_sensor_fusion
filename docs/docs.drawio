        <mxCell id="PgXgIErbtofydOsdPhDl-31" value="if recovery_failed&lt;div&gt;&amp;nbsp;&amp;amp;&amp;amp; retry count &amp;lt; MAX_RETRIES&lt;/div&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" vertex="1" connectable="0" parent="PgXgIErbtofydOsdPhDl-24">
